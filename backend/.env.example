# Voice Demo Studio - Python FastAPI Backend
# Copy this file to .env and fill in your configuration

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development

# Frontend CORS Settings
CORS_ORIGIN=http://localhost:3000

# File Upload Settings
UPLOAD_TEMP_DIR=./tmp
MAX_FILE_SIZE=25000000
ALLOWED_AUDIO_TYPES=["mp3","wav","m4a","ogg","webm"]

# Transcription Service Configuration
# Options: sarvam (for Hinglish), openai (for English), auto (try Sarvam first, fallback to OpenAI)
TRANSCRIPTION_SERVICE=sarvam

# API Keys
# Sarvam AI - Best for Hindi, Hinglish, and Indian languages
# Get API key from: https://sarvam.ai/
SARVAM_API_KEY=your-sarvam-api-key-here

# OpenAI Whisper or OpenRouter
# Get OpenAI key from: https://platform.openai.com/api-keys
# Get OpenRouter key from: https://openrouter.ai/
OPENAI_API_KEY=sk-your-openai-key-here

# API Base URL (use one of these)
# For OpenAI: https://api.openai.com/v1 (default)
# For OpenRouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Logging Level
LOG_LEVEL=INFO
