  "transcript": [
    {
      "id": "seg_1",
      "start": 0.00,
      "end": 0.03,
      "speaker": "customer",
      "text": "Hi, I need help with a loan"
    },
    {
      "id": "seg_2",
      "start": 0.03,
      "end": 0.08,
      "speaker": "ai",
      "text": "Hello! I'd be happy to help you find the right loan product. Are you looking for a personal loan, business loan, or property-based loan?"
    },
    {
      "id": "seg_3",
      "start": 0.08,
      "end": 0.11,
      "speaker": "customer",
      "text": "I'm interested in a business loan for my startup"
    },
    {
      "id": "seg_4",
      "start": 0.11,
      "end": 0.16,
      "speaker": "ai",
      "text": "Great! Business loans are perfect for startups. Let me gather some information. How long has your business been operating?"
    },
    {
      "id": "seg_5",
      "start": 0.16,
      "end": 0.18,
      "speaker": "customer",
      "text": "About 2 years now"
    },
    {
      "id": "seg_6",
      "start": 0.18,
      "end": 0.23,
      "speaker": "ai",
      "text": "Perfect. With 2 years of operation, you qualify for our business loan program. Can you tell me your annual revenue?"
    },
    {
      "id": "seg_7",
      "start": 0.23,
      "end": 0.26,
      "speaker": "customer",
      "text": "Around 5 lakhs per year"
    },
    {
      "id": "seg_8",
      "start": 0.26,
      "end": 0.31,
      "speaker": "ai",
      "text": "That's excellent for a 2-year-old business. Based on your profile, you could qualify for up to 25 lakhs"
    },
    {
      "id": "seg_9",
      "start": 0.31,
      "end": 0.34,
      "speaker": "customer",
      "text": "That sounds good. What's the process to apply?"
    },
    {
      "id": "seg_10",
      "start": 0.34,
      "end": 0.40,
      "speaker": "ai",
      "text": "We'll need your business registration documents, tax returns, and bank statements. The approval process typically takes 5-7 business days"
    },
    {
      "id": "seg_11",
      "start": 0.40,
      "end": 0.43,
      "speaker": "customer",
      "text": "Can I apply online right now?"
    },
    {
      "id": "seg_12",
      "start": 0.43,
      "end": 0.48,
      "speaker": "ai",
      "text": "Yes, absolutely! I can guide you through the application process or connect you with a specialist for more detailed assistance"
    },
    {
      "id": "seg_13",
      "start": 0.48,
      "end": 0.50,
      "speaker": "customer",
      "text": "Let me speak with a specialist"
    },
    {
      "id": "seg_14",
      "start": 0.50,
      "end": 0.55,
      "speaker": "ai",
      "text": "Perfect! Let me connect you with our loan specialist team. They'll be with you in just a moment. Thank you for choosing us"
    },
    {
      "id": "seg_15",
      "start": 0.55,
      "end": 1.00,
      "speaker": "human_agent",
      "text": "Hello, this is Rajesh from our loan team. I see you're interested in a business loan. Let me help you with the details"
    },
    {
      "id": "seg_16",
      "start": 1.00,
      "end": 1.05,
      "speaker": "human_agent",
      "text": "We'll process your application and you should hear back within 5 business days. Is there anything else I can clarify?"
    }
  ],
